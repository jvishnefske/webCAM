{
  "private": true,
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./src/input.css -o ./dist/styles.css --minify",
    "build:js": "node esbuild.config.mjs",
    "build": "npm run build:css && npm run build:js",
    "watch:css": "npx @tailwindcss/cli -i ./src/input.css -o ./dist/styles.css --watch",
    "watch:js": "node esbuild.config.mjs --watch",
    "watch": "npm run watch:css & npm run watch:js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "esbuild": "^0.24.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
